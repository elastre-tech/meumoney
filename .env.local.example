# ==============================================================
# MeuMoney — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ==============================================================

# --------------------------------------------------------------
# Supabase
# Pegar em: supabase.com → seu projeto → Settings → API
# --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# "Project URL" — começa com https://xxx.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=
# "anon public" key — pode ficar no client, RLS protege os dados

SUPABASE_SERVICE_ROLE_KEY=
# "service_role" key (secret!) — NUNCA expor no browser
# Usado pelo webhook pra bypassar RLS e criar usuários

# --------------------------------------------------------------
# WhatsApp Cloud API (Meta)
# Pegar em: developers.facebook.com → seu app → WhatsApp → API Setup
# --------------------------------------------------------------
WA_ACCESS_TOKEN=
# Token permanente do System User
# Criar em: Meta Business Settings → System Users → Add System User
# → gerar token com permissão whatsapp_business_messaging
# O token temporário da API Setup expira em 24h — NÃO use em produção

WA_PHONE_NUMBER_ID=
# ID numérico do telefone (NÃO é o número em si)
# Fica em: WhatsApp → API Setup → campo "Phone number ID"

WEBHOOK_VERIFY_TOKEN=meumoney_verify_2026
# Token que VOCÊ define — pode ser qualquer string segura
# Precisa ser IGUAL ao que você cola no Meta ao configurar o webhook
# URL do webhook: https://seu-dominio.com/api/webhook

WA_APP_SECRET=
# App Secret do Meta App (usado pra validar HMAC do webhook)
# Pegar em: developers.facebook.com → seu app → Settings → Basic → App Secret
# OBRIGATÓRIO em produção — sem ele o webhook aceita requests não autenticados

# --------------------------------------------------------------
# Anthropic — Claude Haiku (OCR de recibos + classificação fallback)
# Pegar em: console.anthropic.com → API Keys
# --------------------------------------------------------------
ANTHROPIC_API_KEY=
# Usado pelo SDK @anthropic-ai/sdk automaticamente
# Funções: OCR de fotos de recibo (Haiku Vision) e classificação
# de transação quando keywords não resolvem
# Sem essa key: texto puro funciona, mas foto e classificação IA não

# --------------------------------------------------------------
# OpenAI — Whisper (transcrição de áudio)
# Pegar em: platform.openai.com → API Keys
# --------------------------------------------------------------
OPENAI_API_KEY=
# Usado para transcrever áudios do WhatsApp via Whisper API
# Sem essa key: tudo funciona exceto áudio — usuário recebe msg pedindo pra digitar

# --------------------------------------------------------------
# App
# --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL pública do app — trocar pra URL da Vercel após deploy
# Ex: https://meumoney.elastre.com.br

# --------------------------------------------------------------
# Notificações de bug report
# --------------------------------------------------------------
BUG_REPORT_NOTIFY_TO=
# Número WhatsApp (formato internacional sem +, ex: 5531946793358)
# que recebe notificação quando alguém manda "reportar" / "bug" / "problema"
# Sem essa var: report fica só na tabela reports, ninguém é avisado
# IMPORTANTE: por causa da janela de 24h da Meta, esse número precisa ter
# mandado mensagem ao bot nas últimas 24h pra receber a notificação.
